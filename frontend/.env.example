NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8055

# WhatsApp: una línea (viejo) o hasta 3 líneas para el botón flotante
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_WHATSAPP_NUMBER_1=
NEXT_PUBLIC_WHATSAPP_NUMBER_2=
NEXT_PUBLIC_WHATSAPP_NUMBER_3=
# Opcional: etiquetas para cada línea de ventas (si no, se usa "Línea 1", "Línea 2", "Línea 3")
NEXT_PUBLIC_WHATSAPP_LABEL_1=Línea de ventas 1
NEXT_PUBLIC_WHATSAPP_LABEL_2=Línea de ventas 2
NEXT_PUBLIC_WHATSAPP_LABEL_3=Línea de ventas 3

# Redes sociales
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_LINKEDIN_URL=

# Admin cotizaciones (página oculta /admin/cotizaciones)
# Clave que el admin debe ingresar para ver el listado
ADMIN_SECRET=
# Token de Directus con permiso de lectura en la colección cotizaciones
DIRECTUS_READ_TOKEN=

# Email de notificación de cotizaciones (Resend)
# RESEND_API_KEY: API key privada de Resend. Nunca exponerla como NEXT_PUBLIC_*.
# RESEND_FROM_EMAIL: remitente verificado en Resend. Puede incluir nombre: Los Álamos <cotizaciones@tu-dominio.com>
# RESEND_NOTIFY_EMAIL: casilla que recibe las cotizaciones.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_NOTIFY_EMAIL=
